<UserControl x:Class="FreeKSeF.App.Views.ZakupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FreeKSeF.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:ZakupViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <DockPanel Margin="12">
        <Border DockPanel.Dock="Top" Background="#F9FAFB" Padding="10" CornerRadius="6" Margin="0,0,0,8">
            <StackPanel>
                <WrapPanel>
                    <TextBlock Text="Okres:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="150" SelectedItem="{Binding Okres}" ItemsSource="{Binding Okresy}" Margin="0,0,24,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><TextBlock Text="{Binding Converter={StaticResource EnumLabel}}" /></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Podgląd / PDF" Command="{Binding PodgladCommand}" />
                    <Button Content="Podgląd zaawansowany" Command="{Binding EdytorCommand}"
                            ToolTip="Wszystkie pola FA(3) otrzymanej faktury (tylko odczyt)" />
                    <Button Content="Zapisz XML" Command="{Binding ZapiszXmlCommand}" />
                    <Button Content="Kolumny…" Click="Kolumny_Click"
                            ToolTip="Wybierz, które kolumny listy mają być widoczne" />
                </WrapPanel>
                <WrapPanel Margin="0,8,0,0">
                    <TextBlock Text="Import z KSeF — miesiąc:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="120" ItemsSource="{Binding Miesiace}" SelectedValue="{Binding ImportMiesiac}"
                              SelectedValuePath="Numer" DisplayMemberPath="Nazwa" Margin="0,0,6,0" />
                    <ComboBox Width="80" ItemsSource="{Binding Lata}" SelectedItem="{Binding ImportRok}" Margin="0,0,12,0" />
                    <Button Content="Pobierz zakupy" Command="{Binding PobierzZakupyCommand}" />
                </WrapPanel>
                <TextBlock Text="{Binding ImportStatus}" Foreground="#4B5563" FontSize="12" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <DataGrid x:Name="Grid" Tag="grid.kolumny.zakup"
                  ItemsSource="{Binding Wiersze}" SelectedItem="{Binding Wybrany}" IsReadOnly="True"
                  PreviewMouseRightButtonDown="Grid_RightClick" MouseDoubleClick="Grid_DoubleClick"
                  Loaded="Grid_Loaded" Unloaded="Grid_Unloaded" ColumnReordered="Grid_ColumnReordered">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Zaznaczona}" Value="True">
                            <Setter Property="Background" Value="#FFF3CD" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="Podgląd / PDF" Command="{Binding PodgladCommand}" />
                    <MenuItem Header="Podgląd zaawansowany" Command="{Binding EdytorCommand}" />
                    <MenuItem Header="Zaznacz / odznacz" Command="{Binding ZaznaczCommand}" />
                    <Separator />
                    <MenuItem Header="Usuń" Command="{Binding UsunCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="St." Binding="{Binding Faktura.Status, Converter={StaticResource StatusSkrot}}" Width="36">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="ToolTip" Value="{Binding Faktura.Status, Converter={StaticResource EnumLabel}}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Status" Binding="{Binding Faktura.Status, Converter={StaticResource EnumLabel}}" Width="110" Visibility="Collapsed" />
                <DataGridTextColumn Header="Numer" Binding="{Binding Faktura.Numer}" Width="*" />
                <DataGridTextColumn Header="Data" Binding="{Binding Faktura.DataWystawienia, StringFormat=d}" Width="95" />
                <DataGridTextColumn Header="Data sprzedaży" Binding="{Binding Faktura.DataSprzedazy, StringFormat=d}" Width="105" Visibility="Collapsed" />
                <DataGridTextColumn Header="Sprzedawca" Binding="{Binding Faktura.KontrahentNazwa}" Width="*" />
                <DataGridTextColumn Header="NIP" Binding="{Binding Faktura.KontrahentNip}" Width="110" />
                <DataGridTextColumn Header="Netto" Binding="{Binding Faktura.SumaNetto, StringFormat=N2}" Width="90" />
                <DataGridTextColumn Header="VAT" Binding="{Binding Faktura.SumaVat, StringFormat=N2}" Width="80" />
                <DataGridTextColumn Header="Brutto" Binding="{Binding Faktura.SumaBrutto, StringFormat=N2}" Width="95" />
                <DataGridTextColumn Header="Waluta" Binding="{Binding Faktura.Waluta}" Width="60" Visibility="Collapsed" />
                <DataGridTextColumn Header="Numer KSeF" Binding="{Binding Faktura.NumerKsef}" Width="170" />
                <DataGridTextColumn Header="Pobrano" Binding="{Binding Utworzono, StringFormat=g}" Width="130" Visibility="Collapsed" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
