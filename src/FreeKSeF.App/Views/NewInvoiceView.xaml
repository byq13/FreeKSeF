<UserControl x:Class="FreeKSeF.App.Views.NewInvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FreeKSeF.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:NewInvoiceViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Naglowek faktury -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Faktura" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                    <Label Content="Numer" />
                    <TextBox Text="{Binding Numer, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Data wystawienia" />
                    <DatePicker SelectedDate="{Binding DataWystawienia}" />
                    <Label Content="Data sprzedazy" />
                    <DatePicker SelectedDate="{Binding DataSprzedazy}" />
                    <Label Content="Waluta" />
                    <ComboBox ItemsSource="{Binding Waluty}" SelectedItem="{Binding Waluta}" />
                    <Label Content="Kurs do PLN (kurs z dnia poprzedniego, edytowalny)" />
                    <TextBox Text="{Binding Kurs, UpdateSourceTrigger=PropertyChanged, StringFormat=N4}"
                             IsEnabled="{Binding KursWidoczny}" />
                </StackPanel>

                <!-- Nabywca -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Nabywca" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                    <Label Content="Wybierz ze slownika" />
                    <ComboBox ItemsSource="{Binding Kontrahenci}"
                              SelectedItem="{Binding WybranyKontrahent}"
                              DisplayMemberPath="Nazwa" />
                    <Label Content="Nazwa" />
                    <TextBox Text="{Binding NabywcaNazwa, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Kraj" />
                    <ComboBox ItemsSource="{Binding Kraje}" SelectedItem="{Binding NabywcaKraj}" IsEditable="True" />
                    <Label Content="NIP / VAT UE / ID (puste = osoba prywatna)" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NabywcaNip, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Content="Pobierz z GUS" Command="{Binding PobierzZGusCommand}"
                                Margin="8,2,0,6" VerticalAlignment="Center" />
                    </Grid>
                    <Label Content="Adres — linia 1" />
                    <TextBox Text="{Binding NabywcaAdresL1, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Adres — linia 2" />
                    <TextBox Text="{Binding NabywcaAdresL2, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Pozycje" FontSize="16" FontWeight="Bold" Margin="0,16,0,4" />
            <DataGrid ItemsSource="{Binding Pozycje}" SelectedItem="{Binding WybranaPozycja}"
                      MinHeight="160">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    <DataGridTextColumn Header="J.m." Binding="{Binding Jednostka, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                    <DataGridTextColumn Header="Ilosc" Binding="{Binding Ilosc, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="70" />
                    <DataGridTextColumn Header="Cena netto" Binding="{Binding CenaNetto, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90" />
                    <DataGridTemplateColumn Header="Stawka" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Stawki, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding Stawka, UpdateSourceTrigger=PropertyChanged}"
                                          BorderThickness="0" Margin="0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumLabel}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Netto" Binding="{Binding WartoscNetto, StringFormat=N2}" IsReadOnly="True" Width="90" />
                    <DataGridTextColumn Header="VAT" Binding="{Binding KwotaVat, StringFormat=N2}" IsReadOnly="True" Width="80" />
                    <DataGridTextColumn Header="Brutto" Binding="{Binding WartoscBrutto, StringFormat=N2}" IsReadOnly="True" Width="90" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="Dodaj pozycje" Command="{Binding DodajPozycjeCommand}" />
                <Button Content="Usun pozycje" Command="{Binding UsunPozycjeCommand}" />
            </StackPanel>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Platnosc -->
                <StackPanel Grid.Column="0" MaxWidth="320" HorizontalAlignment="Left">
                    <TextBlock Text="Platnosc" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                    <Label Content="Forma platnosci" />
                    <ComboBox ItemsSource="{Binding FormyPlatnosci}" SelectedItem="{Binding FormaPlatnosci}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumLabel}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Label Content="Termin platnosci" />
                    <DatePicker SelectedDate="{Binding TerminPlatnosci}" />
                    <Label Content="Numer rachunku" />
                    <TextBox Text="{Binding NrRachunku, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- Podsumowanie -->
                <Border Grid.Column="2" Background="#F3F4F6" Padding="16" CornerRadius="6" VerticalAlignment="Top">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Netto:" Margin="0,0,12,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SumaNetto, StringFormat=N2}" TextAlignment="Right" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="VAT:" Margin="0,0,12,4" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SumaVat, StringFormat=N2}" TextAlignment="Right" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Brutto:" FontWeight="Bold" Margin="0,4,12,0" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SumaBrutto, StringFormat=N2}" FontWeight="Bold" TextAlignment="Right" Margin="0,4,0,0" />
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="Zapisz do bufora" Command="{Binding ZapiszCommand}" />
                <Button Content="Zapisz i podgląd" Command="{Binding ZapiszIPodgladCommand}" />
                <Button Content="Eksportuj XML" Command="{Binding EksportujXmlCommand}" />
            </StackPanel>
            <TextBlock Text="Faktura trafia do bufora (robocza). Wysyłkę do KSeF wykonasz w zakładce „Sprzedaż” po potwierdzeniu."
                       Foreground="#6B7280" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
