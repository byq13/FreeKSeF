<Window x:Class="FreeKSeF.App.Views.HasloWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hasło do tokena KSeF" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock x:Name="Opis" TextWrapping="Wrap" Margin="0,0,0,10" />
        <PasswordBox x:Name="HasloBox" Padding="4,3" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK" IsDefault="True" Click="Ok_Click" MinWidth="80" Margin="0,0,8,0" />
            <Button Content="Anuluj" IsCancel="True" MinWidth="80" />
        </StackPanel>
    </StackPanel>
</Window>
