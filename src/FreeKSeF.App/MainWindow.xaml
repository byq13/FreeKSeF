<Window x:Class="FreeKSeF.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FreeKSeF.App.ViewModels"
        xmlns:views="clr-namespace:FreeKSeF.App.Views"
        Title="FreeKSeF — Szybka Faktura KSeF" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1F2937" Padding="14,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="Firma:" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox MinWidth="240" ItemsSource="{Binding Firmy}" SelectedItem="{Binding AktywnaFirma}"
                              DisplayMemberPath="Nazwa" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="FreeKSeF" Foreground="White" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="  •  darmowe faktury KSeF dla JDG" Foreground="#9CA3AF" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Margin="8" SelectionChanged="Zakladki_SelectionChanged">
            <TabItem Header="Sprzedaż">
                <views:SprzedazView DataContext="{Binding Sprzedaz}" />
            </TabItem>
            <TabItem Header="Zakup">
                <views:ZakupView DataContext="{Binding Zakup}" />
            </TabItem>
            <TabItem Header="Nowa faktura">
                <views:NewInvoiceView DataContext="{Binding NowaFaktura}" />
            </TabItem>
            <TabItem Header="Kontrahenci">
                <views:ContractorsView DataContext="{Binding Kontrahenci}" />
            </TabItem>
            <TabItem Header="Produkty">
                <views:ProductsView DataContext="{Binding Produkty}" />
            </TabItem>
            <TabItem Header="Ustawienia">
                <views:SettingsView DataContext="{Binding Ustawienia}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
