<Application x:Class="FreeKSeF.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FreeKSeF.App.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <conv:EnumLabelConverter x:Key="EnumLabel" />

        <!-- Proste, czytelne style dla calej aplikacji -->
        <Style TargetType="{x:Type Label}">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,2,0,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,2,0,6" />
        </Style>
        <Style TargetType="{x:Type DatePicker}">
            <Setter Property="Margin" Value="0,2,0,6" />
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="90" />
        </Style>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
        </Style>
    </Application.Resources>
</Application>
